# 数据库（PostgreSQL / Supabase）
DB_DSN=postgresql://user:password@host:5432/postgres

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your_service_role_or_anon_key
SUPABASE_PUBLISHABLE_KEY=your_anon_key_for_frontend
BUCKET=commodity

# 可选：管理后台
ADMIN_USER=admin
ADMIN_PASS=admin123
ADMIN_GOOGLE_TOTP=123456

PORT=3001
